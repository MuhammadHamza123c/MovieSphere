{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip install -r requirements.txt && cd frontend && npm install && npm run build",
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "app/main.py", "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"] },
    { "src": "/MovieSphere/(.*)", "dest": "app/main.py", "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"] },
    { "src": "/(.*)", "dest": "app/main.py" }
  ]
}